---
const [, key = ""] = Astro.url.pathname.split("/");
---

<nav class="flex">
  <a class:list={[{ "bg-slate-200": key == "" }]} href="/">文章</a>
  <a class:list={[{ "bg-slate-200": key == "list" }]} href="/list">目录</a>
  <a class:list={[{ "bg-slate-200": key == "tags" }]} href="/tags">索引</a>
  <a class:list={[{ "bg-slate-200": key == "about" }]} href="/about">关于</a>

</nav>

<style>
  @reference "../styles/global.css";
  nav a {
    @apply text-blue-500 text-lg px-5;

    &:hover {
      @apply text-blue-800 underline underline-offset-4;
    }
  }
</style>
