---

<header>
  <div class="mx-auto max-w-7xl pb-2 sm:pb-2 sm:py-4 lg:px-8">
    <div class="sm:flex sm:items-center sm:justify-between">
      <div class="text-center sm:text-left">
        <span class="text-2xl font-bold text-gray-900 sm:text-3xl">
          oldyang博客
        </span>
        <p class="mt-1.5 text-sm text-gray-500">
          这里是oldyang(老杨)的博客,欢迎光临！
        </p>
      </div>
      <div class="flex items-center">
        <button
          id="theme-toggle"
          type="button"
          class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-zinc-700 dark:text-zinc-300 dark:hover:bg-zinc-800 transition-colors"
        >
          切换主题
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("theme-toggle");
  if (btn) {
    btn.addEventListener("click", () => {
      const html = document.documentElement;
      const isDark = html.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  }
</script>
